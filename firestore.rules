rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permite leitura e escrita apenas para usuários autenticados no sistema
      // A filtragem lógica (quem vê qual cliente) é feita via código no App.tsx
      allow read, write: if request.auth != null;
    }
  }
}